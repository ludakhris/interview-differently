generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Scenario {
  scenarioId String   @id
  status     String   @default("draft")
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SimulationResult {
  id              String           @id
  userId          String
  scenarioId      String
  scenarioTitle   String
  track           String
  completedAt     DateTime
  overallScore    Int
  choiceSequence  String[]
  aiFeedback      Json?
  createdAt       DateTime         @default(now())
  dimensionScores DimensionScore[]

  @@index([userId])
  @@index([userId, scenarioId])
}

model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DimensionScore {
  id                 String           @id @default(uuid())
  simulationResultId String
  dimension          String
  score              Int
  quality            String
  feedback           String
  simulationResult   SimulationResult @relation(fields: [simulationResultId], references: [id], onDelete: Cascade)

  @@index([simulationResultId])
}

model ImmersiveSession {
  id         String               @id @default(uuid())
  scenarioId String
  userId     String
  status     String               @default("active") // active | completed | abandoned
  summary    Json?                // cached ImmersiveSummary once all responses are evaluated
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  responses  ImmersiveResponse[]

  @@index([userId])
  @@index([scenarioId])
}

model ImmersiveResponse {
  id              String           @id @default(uuid())
  sessionId       String
  nodeId          String
  questionText    String
  mediaUrl        String?
  transcript      String?
  durationSeconds Int?
  aiFeedback      Json?            // cached ImmersiveResponseFeedback
  createdAt       DateTime         @default(now())
  session         ImmersiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ScenarioRequest {
  id               String   @id @default(uuid())
  // Briefing
  situation        String                            // required
  role             String?
  reportsTo        String?
  timeInRole       String?
  // Scenario context
  otherPeople      String?
  metricsContext   String?
  timePressure     String?
  hardestMoment    String                            // required
  temptingWrong    String?
  greatLooksLike   String?
  // Categorisation
  track            String?  // operations | business | risk | customer-success | general | custom
  estimatedMinutes Int?
  // Contact (all optional — anonymous submissions allowed)
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  // Triage
  status           String   @default("new")          // new | contacted | building | published | declined
  emailSent        Boolean  @default(false)
  emailError       String?
  notes            String?
  // System
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Institution analytics (Phase 6) ────────────────────────────────────────
//
// Institutions group cohorts; cohorts group students. Both are pure grouping
// mechanisms — a single user can belong to multiple cohorts (and therefore
// multiple institutions), so Membership is many-to-many.
//
// User is a thin local mirror of the Clerk user, populated lazily on first
// interaction with institution endpoints. We cache email/name so analytics
// queries don't have to round-trip to Clerk for every name lookup.

model User {
  id          String       @id              // Clerk userId — no separate uuid
  email       String?      @unique          // cached from Clerk; nullable until first sync
  displayName String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]

  @@index([email])
}

model Institution {
  id          String       @id @default(uuid())
  name        String
  // Optional. When set, students whose Clerk email matches this domain
  // can be auto-suggested into the institution at signup (Phase 6b).
  // When null, the only way in is the cohort joinKey or admin-add.
  // Postgres unique-constraint treats each NULL as distinct, so multiple
  // institutions can share the "no domain" state.
  emailDomain String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cohorts     Cohort[]
  memberships Membership[]
}

model Cohort {
  id            String       @id @default(uuid())
  institutionId String
  name          String
  joinKey       String?      @unique         // optional — students enter this at signup to auto-join
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  memberships   Membership[]

  @@index([institutionId])
}

model Membership {
  id            String      @id @default(uuid())
  userId        String                          // Clerk userId — FK to User.id
  institutionId String
  cohortId      String?                          // null = institution member but no cohort yet
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  cohort        Cohort?     @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  @@unique([userId, institutionId, cohortId])  // a user can only be in a given (institution, cohort) once
  @@index([userId])
  @@index([institutionId])
  @@index([cohortId])
}

model ScenarioMediaAsset {
  id           String   @id @default(uuid())
  scenarioId   String
  nodeId       String
  scriptHash   String   // sha256 of audioScript at render time; mismatch ⇒ stale ⇒ re-render
  presenterId  String   // D-ID presenter id baked into the clip
  voiceId      String   // Azure voice id baked into the clip
  status       String   // queued | rendering | ready | failed
  mediaUrl     String?  // R2 public URL once status='ready'
  durationMs   Int?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([scenarioId, nodeId])
  @@index([scenarioId])
  @@index([status])
}
