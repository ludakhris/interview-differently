generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Scenario {
  scenarioId String   @id
  status     String   @default("draft")
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SimulationResult {
  id              String           @id
  userId          String
  scenarioId      String
  scenarioTitle   String
  track           String
  completedAt     DateTime
  overallScore    Int
  choiceSequence  String[]
  createdAt       DateTime         @default(now())
  dimensionScores DimensionScore[]

  @@index([userId])
  @@index([userId, scenarioId])
}

model DimensionScore {
  id                 String           @id @default(uuid())
  simulationResultId String
  dimension          String
  score              Int
  quality            String
  feedback           String
  simulationResult   SimulationResult @relation(fields: [simulationResultId], references: [id], onDelete: Cascade)

  @@index([simulationResultId])
}
