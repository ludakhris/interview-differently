{
  "name": "@id/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "backfill:media": "ts-node -r tsconfig-paths/register scripts/backfill-scenario-media.ts",
    "seed:fake": "ts-node -r tsconfig-paths/register scripts/seed-fake-cohort.ts"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@clerk/backend": "^3.4.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "dotenv": "^17.4.1",
    "js-yaml": "^4.1.1",
    "openai": "^6.34.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.12.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.5.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
